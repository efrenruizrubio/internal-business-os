{
  "name": "internal-business-os",
  "private": true,
  "packageManager": "bun@1.3.9",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "prisma:format": "bunx prisma format --schema apps/server/prisma",
    "prisma:validate": "bunx prisma validate --schema apps/server/prisma",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "prepare": "husky",
    "test": "vitest run --passWithNoTests"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,mjs,json,md,yml,html,css}": [
      "prettier --write"
    ],
    "apps/server/prisma/**/*.prisma": [
      "bunx prisma format --schema apps/server/prisma",
      "git add apps/server/prisma/**/*.prisma"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@repo/config": "workspace:*",
    "@types/bun": "latest",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
