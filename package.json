{
  "name": "simplebusiness-monorepo-template",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "prepare": "husky",
    "test": "vitest run --passWithNoTests"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,mjs,json,md,yml,html,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/bun": "latest",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
